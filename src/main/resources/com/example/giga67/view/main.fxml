<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.giga67.controller.MainController"
            styleClass="root">

    <!-- Голова -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-top">
            <padding>
                <Insets top="15" right="30" bottom="15" left="30"/>
            </padding>

            <Label text="MasterParts" styleClass="logo"/>
            <Label fx:id="locationLabel" text="г.Энгельс" styleClass="location"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button text="Заказы"
                    onAction="#handleOrders"
                    styleClass="header-button"/>

            <Button text="Избранное"
                    onAction="#handleFavorites"
                    styleClass="header-button"/>

            <Button text="Корзина"
                    onAction="#handleCart"
                    styleClass="header-button"/>

            <Button text="Профиль"
                    onAction="#handleLogin"
                    styleClass="primary-button"/>
        </HBox>
    </top>

    <!-- Содержимое -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="30" alignment="TOP_CENTER">
                <padding>
                    <Insets top="20" right="30" bottom="20" left="30"/>
                </padding>

                <!-- Секция поиска -->
                <VBox spacing="25" alignment="CENTER" styleClass="search-section">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <Label text="Найдите нужную автозапчасть"
                           styleClass="search-title"/>

                    <HBox spacing="15" alignment="CENTER" maxWidth="700">
                        <TextField fx:id="searchField"
                                   promptText="Введите название или артикул..."
                                   styleClass="search-input"
                                   HBox.hgrow="ALWAYS"/>

                        <Button text="🔍 Найти"
                                onAction="#handleSearch"
                                styleClass="search-button"/>

                        <Button text="Фильтры"
                                fx:id="filtersButton"
                                onAction="#handleFilters"
                                styleClass="search-button"/>
                    </HBox>
                </VBox>

                <!-- Секция категорий -->
                <VBox spacing="25" alignment="TOP_CENTER">
                    <Label text="Категории"
                           styleClass="section-title"/>

                    <FlowPane fx:id="categoriesPane"
                              hgap="20"
                              vgap="20"
                              alignment="CENTER"
                              prefWrapLength="1200"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>