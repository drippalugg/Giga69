<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.giga67.controller.CartController"
            styleClass="root">

    <!-- Голова -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-top">
            <padding>
                <Insets top="15" right="30" bottom="15" left="30"/>
            </padding>

            <Button text="Назад" onAction="#goBack" styleClass="back-button"/>
            <Label text="Корзина" styleClass="page-title"/>
        </HBox>
    </top>

    <!-- Содержимое -->
    <center>
        <VBox spacing="20" styleClass="cart-container">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- StackPane для центрирования сообщения -->
            <StackPane VBox.vgrow="ALWAYS">
                <!-- ListView для товаров -->
                <ListView fx:id="cartListView"
                          styleClass="cart-list"
                          style="-fx-background-color: transparent;"/>

                <!-- Центрированное сообщение для пустой корзины -->
                <Label fx:id="emptyLabel"
                       text="Корзина пуста"
                       styleClass="empty-message"
                       visible="false"
                       StackPane.alignment="CENTER"/>
            </StackPane>

            <!-- Итого -->
            <HBox alignment="CENTER_RIGHT" spacing="20">
                <Label fx:id="totalLabel" text="Итого: 0.00 ₽" styleClass="total-label"/>
            </HBox>

            <!-- Кнопки действий -->
            <HBox spacing="15" alignment="CENTER">
                <Button text="Очистить корзину"
                        onAction="#handleClearCart"
                        styleClass="danger-button"/>

                <Button text="Оформить заказ"
                        onAction="#handleCheckout"
                        styleClass="primary-button-large"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
